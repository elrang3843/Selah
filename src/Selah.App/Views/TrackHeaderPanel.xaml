<UserControl x:Class="Selah.App.Views.TrackHeaderPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Selah.App.ViewModels"
             Background="{DynamicResource SurfaceBrush}"
             MinWidth="180">

    <DockPanel>
        <!-- 눈금자 높이에 맞춘 헤더 여백 -->
        <Border DockPanel.Dock="Top" Height="28" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="0,0,0,1">
            <TextBlock Text="{DynamicResource Track_Header}" Foreground="{DynamicResource Overlay0Brush}" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- 메트로놈 트랙 (#0) — "메트로놈" 활성화 시에만 표시 -->
        <Border DockPanel.Dock="Top" Height="40"
                Background="{DynamicResource MetronomeSurfaceBrush}"
                BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="0,0,0,1"
                Visibility="{Binding IsMetronomeOn, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center">
                <Rectangle Width="4" Height="16" Margin="0,0,6,0" RadiusX="2" RadiusY="2"
                           Fill="{DynamicResource Surface2Brush}"/>
                <TextBlock Text="0" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{DynamicResource Track_Metronome}" Foreground="{DynamicResource Overlay0Brush}" FontSize="11"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 트랙 목록 -->
        <ItemsControl ItemsSource="{Binding CurrentProject.Tracks}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TrackViewModel}">
                    <Border Height="{Binding HeightPixels}"
                            BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="0,0,0,1"
                            Background="{DynamicResource BgBrush}">
                        <Grid Margin="6,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 트랙 이름 + 색상 표시 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <Rectangle Width="4" Height="16" Margin="0,0,6,0"
                                           RadiusX="2" RadiusY="2">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="{Binding Color,
                                            Converter={StaticResource HexToColorConverter}}"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <!-- TextBox는 TextTrimming 미지원 → MaxWidth로 대체 -->
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"
                                         FontSize="12" MaxWidth="130"/>
                            </StackPanel>

                            <!-- 뮤트 / 솔로 버튼 -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                                <ToggleButton Content="M" ToolTip="{DynamicResource Track_Tooltip_Mute}"
                                              IsChecked="{Binding Muted}"
                                              Command="{Binding MuteCommand}"
                                              Width="24" Height="20" FontSize="10"
                                              Foreground="{Binding Muted,
                                                  Converter={StaticResource MuteColorConverter}}"/>
                                <ToggleButton Content="S" ToolTip="{DynamicResource Track_Tooltip_Solo}"
                                              IsChecked="{Binding Solo}"
                                              Command="{Binding SoloCommand}"
                                              Width="24" Height="20" FontSize="10"
                                              Margin="3,0,0,0"
                                              Foreground="{Binding Solo,
                                                  Converter={StaticResource SoloColorConverter}}"/>
                            </StackPanel>

                            <!-- 볼륨 슬라이더 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Track_Vol}" Foreground="{DynamicResource Overlay0Brush}" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <Slider Minimum="-60" Maximum="12"
                                        Value="{Binding GainDb}"
                                        Width="80" VerticalAlignment="Center"
                                        ToolTip="{Binding GainDb, StringFormat='{}{0:F1} dB'}"/>
                                <TextBlock Text="{Binding GainDb, StringFormat='{}{0:F1}'}"
                                           Foreground="{DynamicResource SubtextBrush}" FontSize="10"
                                           VerticalAlignment="Center" Margin="4,0,0,0" Width="30"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
