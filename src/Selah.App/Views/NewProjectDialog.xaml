<Window x:Class="Selah.App.Views.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource NewProject_Title}"
        Icon="pack://application:,,,/Resources/Selah.ico"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0" Text="{DynamicResource NewProject_Heading}"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="#89B4FA" Margin="0,0,0,20"/>

        <!-- 프로젝트 이름 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <Label Content="{DynamicResource NewProject_NameLabel}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtName"
                     FontSize="14" Height="34"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- 샘플레이트 선택 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <Label Content="{DynamicResource NewProject_SampleRate}" Margin="0,0,0,8"/>

            <RadioButton x:Name="Rb32k" GroupName="SampleRate"
                         Content="{DynamicResource NewProject_32k}"
                         Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,6" Height="Auto"/>
            <RadioButton x:Name="Rb44k" GroupName="SampleRate"
                         Content="{DynamicResource NewProject_44k}"
                         Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,6" Height="Auto"/>
            <RadioButton x:Name="Rb48k" GroupName="SampleRate"
                         Content="{DynamicResource NewProject_48k}"
                         Foreground="#CDD6F4" FontSize="12" FontWeight="SemiBold"
                         IsChecked="True" Margin="0,0,0,6" Height="Auto"/>
            <RadioButton x:Name="Rb96k" GroupName="SampleRate"
                         Content="{DynamicResource NewProject_96k}"
                         Foreground="#A6ADC8" FontSize="12" Height="Auto"/>
        </StackPanel>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="{DynamicResource NewProject_Cancel}" Width="80" Height="34"
                    Style="{StaticResource DefaultButton}"
                    IsCancel="True" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource NewProject_Create}" Width="90" Height="34"
                    Style="{StaticResource AccentButton}"
                    IsDefault="True"
                    Click="BtnCreate_Click"/>
        </StackPanel>
    </Grid>
</Window>
