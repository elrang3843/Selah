<Window x:Class="Selah.App.Views.ModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Selah.App.ViewModels"
        Title="모델 관리자 (Model Manager)"
        Width="780" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        ShowInTaskbar="False">

    <!-- 앱 전역 컨버터 사용 (App.xaml에 등록됨) -->

    <DockPanel Margin="0">

        <!-- 상태 바 -->
        <StatusBar DockPanel.Dock="Bottom" Background="#181825" Height="28">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#A6ADC8" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="120" Height="6"
                             IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 상단 툴바 -->
        <Border DockPanel.Dock="Top" Background="#181825" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="새로고침" Command="{Binding RefreshCommand}"
                        Style="{StaticResource DefaultButton}" Width="90" Height="30"
                        Margin="0,0,8,0"/>
                <Button Content="Demucs 설치 (pip)" Command="{Binding InstallDemucsCommand}"
                        Style="{StaticResource AccentButton}" Width="150" Height="30"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Margin="0,0,16,0"/>
                <TextBlock VerticalAlignment="Center" Foreground="#7F849C" FontSize="11"
                           Text="Python + pip이 설치되어 있어야 합니다. 설치에 수 분이 걸릴 수 있습니다."/>
            </StackPanel>
        </Border>

        <!-- 좌: 모델 목록 / 우: 상세 정보 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 모델 목록 -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Models}"
                     SelectedItem="{Binding SelectedModel}"
                     Background="#181825"
                     BorderThickness="0"
                     Padding="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#CDD6F4"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#313244"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#313244"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#262637"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding IsInstalled,
                                            Converter={StaticResource InstalledColorConverter}}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           FontSize="13" Foreground="#CDD6F4"/>
                            </StackPanel>
                            <TextBlock Text="{Binding License}" Foreground="#7F849C"
                                       FontSize="11" Margin="14,0,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="14,2,0,0">
                                <TextBlock Foreground="{Binding IsInstalled,
                                            Converter={StaticResource InstalledTextBrushConverter}}"
                                           FontSize="11"
                                           Text="{Binding IsInstalled,
                                               Converter={StaticResource InstalledStatusConverter}}"/>
                                <TextBlock Text=" · " Foreground="#45475A" FontSize="11"/>
                                <TextBlock Text="{Binding SizeDisplay}"
                                           Foreground="#6C7086" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="#313244" Cursor="SizeWE"/>

            <!-- 상세 정보 -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          Background="#1E1E2E" Padding="20">
                <StackPanel Visibility="{Binding SelectedModel,
                    Converter={StaticResource NullToVisibilityConverter}}">

                    <TextBlock Text="{Binding SelectedModel.Name}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="#89B4FA" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedModel.Version,
                                StringFormat='버전: {0}'}"
                               Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,16"/>

                    <!-- 설명 -->
                    <TextBlock Text="{Binding SelectedModel.Description}"
                               TextWrapping="Wrap" Foreground="#CDD6F4"
                               LineHeight="22" Margin="0,0,0,20"/>

                    <!-- 스템 타입 / 엔진 / 라이선스 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="분리 방식"
                                   Foreground="#6C7086" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Foreground="#CDD6F4" FontSize="12"
                                   Text="{Binding SelectedModel.StemType}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="실행 엔진"
                                   Foreground="#6C7086" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#CDD6F4" FontSize="12"
                                   Margin="0,4,0,0" Text="{Binding SelectedModel.Engine}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="라이선스"
                                   Foreground="#6C7086" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Foreground="#A6E3A1" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,4,0,0"
                                   Text="{Binding SelectedModel.License}"/>
                    </Grid>

                    <!-- 예배 주의사항 -->
                    <Border Background="#2A2A1A" BorderBrush="#F9E2AF"
                            BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="⚠ 저작권/라이선스 안내"
                                       Foreground="#F9E2AF" FontWeight="SemiBold"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding SelectedModel.WorshipNote}"
                                       TextWrapping="Wrap" Foreground="#F9E2AF"
                                       FontSize="11" LineHeight="18"/>
                        </StackPanel>
                    </Border>

                    <!-- 링크 버튼 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="소스/GitHub 열기"
                                Command="{Binding OpenSourceUrlCommand}"
                                CommandParameter="{Binding SelectedModel.SourceUrl}"
                                Style="{StaticResource DefaultButton}"
                                Height="30" Margin="0,0,8,0"/>
                        <Button Content="라이선스 원문 보기"
                                Command="{Binding OpenLicenseUrlCommand}"
                                CommandParameter="{Binding SelectedModel.LicenseUrl}"
                                Style="{StaticResource DefaultButton}"
                                Height="30"/>
                    </StackPanel>

                    <!-- 설치 상태 표시 -->
                    <Border CornerRadius="4" Padding="12,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A2A1A"/>
                                <Setter Property="BorderBrush" Value="#A6E3A1"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedModel.IsInstalled}"
                                                 Value="False">
                                        <Setter Property="Background" Value="#1E1E2E"/>
                                        <Setter Property="BorderBrush" Value="#45475A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="13" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"
                                            Value="✓ 설치됨 — MR 추출 기능 사용 가능"/>
                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding SelectedModel.IsInstalled}"
                                            Value="False">
                                            <Setter Property="Text"
                                                    Value="미설치 — 위의 'Demucs 설치' 버튼을 클릭하거나 pip install demucs 를 실행하세요."/>
                                            <Setter Property="Foreground" Value="#A6ADC8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
