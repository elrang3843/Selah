<Window x:Class="Selah.App.Views.ModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Selah.App.ViewModels"
        Title="{DynamicResource ModelManager_Title}"
        Width="780" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        ShowInTaskbar="False">

    <!-- 앱 전역 컨버터 사용 (App.xaml에 등록됨) -->

    <DockPanel Margin="0">

        <!-- 상태 바 -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}" Height="28">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SubtextBrush}" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="120" Height="6"
                             IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 상단 툴바 -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="{DynamicResource ModelManager_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource DefaultButton}" Width="90" Height="30"
                        Margin="0,0,8,0"/>
                <Button Content="{DynamicResource ModelManager_InstallDemucs}"
                        Command="{Binding InstallDemucsCommand}"
                        Style="{StaticResource AccentButton}" Width="160" Height="30"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Margin="0,0,16,0"/>
                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Overlay0Brush}" FontSize="11"
                           Text="{DynamicResource ModelManager_PipHint}"/>
            </StackPanel>
        </Border>

        <!-- 좌: 모델 목록 / 우: 상세 정보 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 모델 목록 -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Models}"
                     SelectedItem="{Binding SelectedModel}"
                     Background="{DynamicResource SurfaceBrush}"
                     BorderThickness="0"
                     Padding="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Surface1Brush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding IsInstalled,
                                            Converter={StaticResource InstalledColorConverter}}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding License}" Foreground="{DynamicResource Overlay0Brush}"
                                       FontSize="11" Margin="14,0,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="14,2,0,0">
                                <TextBlock Foreground="{Binding IsInstalled,
                                            Converter={StaticResource InstalledTextBrushConverter}}"
                                           FontSize="11"
                                           Text="{Binding IsInstalled,
                                               Converter={StaticResource InstalledStatusConverter}}"/>
                                <TextBlock Text=" · " Foreground="{DynamicResource Surface2Brush}" FontSize="11"/>
                                <TextBlock Text="{Binding SizeDisplay}"
                                           Foreground="{DynamicResource Overlay0Brush}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Surface1Brush}" Cursor="SizeWE"/>

            <!-- 상세 정보 -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource BgBrush}" Padding="20">
                <StackPanel Visibility="{Binding SelectedModel,
                    Converter={StaticResource NullToVisibilityConverter}}">

                    <TextBlock Text="{Binding SelectedModel.Name}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>

                    <!-- 버전: 레이블 + 값 분리 (DynamicResource 사용) -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="{DynamicResource ModelManager_Version}"
                                   Foreground="{DynamicResource SubtextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedModel.Version}"
                                   Foreground="{DynamicResource SubtextBrush}" FontSize="12"/>
                    </StackPanel>

                    <!-- 설명 -->
                    <TextBlock Text="{Binding SelectedModel.Description}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"
                               LineHeight="22" Margin="0,0,0,20"/>

                    <!-- 스템 타입 / 엔진 / 라이선스 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ModelManager_StemType}"
                                   Foreground="{DynamicResource Overlay0Brush}" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextBrush}" FontSize="12"
                                   Text="{Binding SelectedModel.StemType}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ModelManager_Engine}"
                                   Foreground="{DynamicResource Overlay0Brush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource TextBrush}" FontSize="12"
                                   Margin="0,4,0,0" Text="{Binding SelectedModel.Engine}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource ModelManager_License}"
                                   Foreground="{DynamicResource Overlay0Brush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource GreenBrush}" FontSize="12"
                                   FontWeight="SemiBold" Margin="0,4,0,0"
                                   Text="{Binding SelectedModel.License}"/>
                    </Grid>

                    <!-- 예배 주의사항 -->
                    <Border Background="{DynamicResource WarningSurfaceBrush}" BorderBrush="{DynamicResource YellowBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ModelManager_Copyright}"
                                       Foreground="{DynamicResource YellowBrush}" FontWeight="SemiBold"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding SelectedModel.WorshipNote}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource YellowBrush}"
                                       FontSize="11" LineHeight="18"/>
                        </StackPanel>
                    </Border>

                    <!-- 링크 버튼 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="{DynamicResource ModelManager_OpenSource}"
                                Command="{Binding OpenSourceUrlCommand}"
                                CommandParameter="{Binding SelectedModel.SourceUrl}"
                                Style="{StaticResource DefaultButton}"
                                Height="30" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource ModelManager_OpenLicense}"
                                Command="{Binding OpenLicenseUrlCommand}"
                                CommandParameter="{Binding SelectedModel.LicenseUrl}"
                                Style="{StaticResource DefaultButton}"
                                Height="30"/>
                    </StackPanel>

                    <!-- 설치 상태 표시: Style 트리거 대신 두 TextBlock + Visibility 전환 -->
                    <Border CornerRadius="4" Padding="12,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessSurfaceBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GreenBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedModel.IsInstalled}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource Surface2Brush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ModelManager_Installed}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource GreenBrush}"
                                       Visibility="{Binding SelectedModel.IsInstalled,
                                           Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{DynamicResource ModelManager_NotInstalled}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SubtextBrush}"
                                       Visibility="{Binding SelectedModel.IsInstalled,
                                           Converter={StaticResource InvBoolToVis}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
