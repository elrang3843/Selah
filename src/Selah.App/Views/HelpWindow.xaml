<Window x:Class="Selah.App.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Help_Window_Title}"
        Width="880" Height="640"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, Malgun Gothic">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════
             왼쪽 사이드바 (네비게이션)
             ══════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Background="{DynamicResource SurfaceBrush}">

            <Border DockPanel.Dock="Top" Padding="18,20,18,16"
                    BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="Selah" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{DynamicResource Help_Nav_Label}" FontSize="11"
                               Foreground="{DynamicResource SubtextBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <ListBox x:Name="NavList"
                     SelectionChanged="NavList_SelectionChanged"
                     Background="Transparent" BorderThickness="0"
                     Padding="0,10,0,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="Foreground"      Value="{DynamicResource SubtextBrush}"/>
                        <Setter Property="BorderBrush"     Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                        <Setter Property="Padding"         Value="0"/>
                        <Setter Property="Margin"          Value="0"/>
                        <Setter Property="Cursor"          Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="15,11,15,11">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource Surface1Brush}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected"  Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface1Brush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBoxItem><TextBlock Text="{DynamicResource Help_Nav_Shortcuts}" FontSize="13"/></ListBoxItem>
                <ListBoxItem><TextBlock Text="{DynamicResource Help_Nav_UserGuide}"  FontSize="13"/></ListBoxItem>
                <ListBoxItem><TextBlock Text="{DynamicResource Help_Nav_Ethics}"     FontSize="13"/></ListBoxItem>
                <ListBoxItem><TextBlock Text="{DynamicResource Help_Nav_About}"      FontSize="13"/></ListBoxItem>
            </ListBox>
        </DockPanel>

        <!-- 세로 구분선 -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource Surface1Brush}"/>

        <!-- ══════════════════════════════════════
             콘텐츠 영역 — HTML 뷰어
             ══════════════════════════════════════ -->
        <WebBrowser x:Name="HelpBrowser" Grid.Column="2"
                    LoadCompleted="HelpBrowser_LoadCompleted"/>
    </Grid>
</Window>
