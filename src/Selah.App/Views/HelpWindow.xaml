<Window x:Class="Selah.App.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Help_Window_Title}"
        Width="880" Height="640"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, Malgun Gothic">

    <Window.Resources>
        <!-- 키 배지 스타일 -->
        <Style x:Key="KeyBadge" TargetType="Border">
            <Setter Property="Background"        Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="CornerRadius"      Value="4"/>
            <Setter Property="Padding"           Value="9,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,0,0"/>
        </Style>
        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
            <Setter Property="FontSize"    Value="11.5"/>
            <Setter Property="Foreground"  Value="{DynamicResource SubtextBrush}"/>
        </Style>
        <!-- 단축키 행의 설명 -->
        <Style x:Key="ShDesc" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Foreground"       Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- 패널 내 카테고리 헤더 -->
        <Style x:Key="CatHead" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Overlay0Brush}"/>
            <Setter Property="Margin"     Value="0,22,0,10"/>
        </Style>
        <!-- 구분선 -->
        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="BorderBrush"     Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
        </Style>
        <!-- 섹션 제목 -->
        <Style x:Key="SecHead" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin"     Value="0,20,0,7"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- 본문 텍스트 -->
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Foreground"   Value="{DynamicResource SubtextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight"   Value="22"/>
        </Style>
        <!-- 도구 설치 소목차 헤더 -->
        <Style x:Key="SubSecHead" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{DynamicResource PeachBrush}"/>
            <Setter Property="Margin"       Value="0,18,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════
             왼쪽 사이드바 (네비게이션)
             ══════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Background="{DynamicResource SurfaceBrush}">

            <!-- 로고 / 제목 영역 -->
            <Border DockPanel.Dock="Top" Padding="18,20,18,16"
                    BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="Selah" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{DynamicResource Help_Nav_Label}" FontSize="11"
                               Foreground="{DynamicResource SubtextBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- 탐색 목록 -->
            <ListBox x:Name="NavList"
                     SelectionChanged="NavList_SelectionChanged"
                     Background="Transparent" BorderThickness="0"
                     Padding="0,10,0,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="Foreground"      Value="{DynamicResource SubtextBrush}"/>
                        <Setter Property="BorderBrush"     Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                        <Setter Property="Padding"         Value="0"/>
                        <Setter Property="Margin"          Value="0"/>
                        <Setter Property="Cursor"          Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="15,11,15,11">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource Surface1Brush}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected"  Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface1Brush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBoxItem>
                    <TextBlock Text="{DynamicResource Help_Nav_Shortcuts}" FontSize="13"/>
                </ListBoxItem>
                <ListBoxItem>
                    <TextBlock Text="{DynamicResource Help_Nav_UserGuide}" FontSize="13"/>
                </ListBoxItem>
                <ListBoxItem>
                    <TextBlock Text="{DynamicResource Help_Nav_Ethics}" FontSize="13"/>
                </ListBoxItem>
                <ListBoxItem>
                    <TextBlock Text="{DynamicResource Help_Nav_About}" FontSize="13"/>
                </ListBoxItem>
            </ListBox>
        </DockPanel>

        <!-- 세로 구분선 -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource Surface1Brush}"/>

        <!-- ══════════════════════════════════════
             콘텐츠 영역 (4개 패널, 하나만 표시)
             ══════════════════════════════════════ -->
        <Grid Grid.Column="2">

            <!-- ─────────────────────────────────
                 패널 0: 단축키 목록
                 ───────────────────────────────── -->
            <ScrollViewer x:Name="PanelShortcuts"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource BgBrush}">
                <StackPanel Margin="32,28,32,36">

                    <TextBlock Text="{DynamicResource Help_Sh_Title}"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                    <Border Style="{StaticResource Divider}" Margin="0,12,0,0"/>

                    <!-- 파일 -->
                    <TextBlock Text="{DynamicResource Help_Sh_Cat_File}" Style="{StaticResource CatHead}"/>
                    <Border Style="{StaticResource Divider}"/>

                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + N" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_NewProject}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + O" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Open}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + S" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Save}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + Shift + S" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_SaveAs}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + E" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Export}" Style="{StaticResource ShDesc}"/>
                    </Grid>

                    <!-- 재생 -->
                    <TextBlock Text="{DynamicResource Help_Sh_Cat_Playback}" Style="{StaticResource CatHead}"/>
                    <Border Style="{StaticResource Divider}"/>

                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Space" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_PlayStop}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Home" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_ReturnToStart}" Style="{StaticResource ShDesc}"/>
                    </Grid>

                    <!-- 편집 -->
                    <TextBlock Text="{DynamicResource Help_Sh_Cat_Edit}" Style="{StaticResource CatHead}"/>
                    <Border Style="{StaticResource Divider}"/>

                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="S" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Split}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Delete" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Delete}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + Z" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Undo}" Style="{StaticResource ShDesc}"
                                   Foreground="{DynamicResource Overlay0Brush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + Y" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Redo}" Style="{StaticResource ShDesc}"
                                   Foreground="{DynamicResource Overlay0Brush}"/>
                    </Grid>

                    <!-- 도구 -->
                    <TextBlock Text="{DynamicResource Help_Sh_Cat_Tools}" Style="{StaticResource CatHead}"/>
                    <Border Style="{StaticResource Divider}"/>

                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="M" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Metronome}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="N" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Snap}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="Ctrl + Wheel" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_Zoom}" Style="{StaticResource ShDesc}"/>
                    </Grid>
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource KeyBadge}"><TextBlock Text="F1" Style="{StaticResource KeyText}"/></Border>
                        <TextBlock Grid.Column="1" Text="{DynamicResource Help_Sh_HelpWindow}" Style="{StaticResource ShDesc}"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ─────────────────────────────────
                 패널 1: 사용 가이드
                 ───────────────────────────────── -->
            <ScrollViewer x:Name="PanelUserGuide"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource BgBrush}">
                <StackPanel Margin="32,28,32,36">

                    <TextBlock Text="{DynamicResource Help_UG_Title}"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                    <Border Style="{StaticResource Divider}" Margin="0,12,0,0"/>

                    <!-- 셀라란? -->
                    <TextBlock Text="{DynamicResource Help_UG_About_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_About_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 시작하기 -->
                    <TextBlock Text="{DynamicResource Help_UG_Start_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Start_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 프로젝트 관리 -->
                    <TextBlock Text="{DynamicResource Help_UG_Project_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Project_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 오디오 가져오기 -->
                    <TextBlock Text="{DynamicResource Help_UG_Import_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Import_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 타임라인 편집 -->
                    <TextBlock Text="{DynamicResource Help_UG_Timeline_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Timeline_Body}" Style="{StaticResource BodyText}"/>

                    <!-- AI 스템 분리 -->
                    <TextBlock Text="{DynamicResource Help_UG_AI_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_AI_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 내보내기 -->
                    <TextBlock Text="{DynamicResource Help_UG_Export_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Export_Body}" Style="{StaticResource BodyText}"/>

                    <!-- ══ 필수 도구 설치 구분선 ══ -->
                    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,1,0,0"
                            Margin="0,32,0,0" Padding="0,18,0,0">
                        <TextBlock Text="{DynamicResource Help_UG_Setup_Head}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Intro}"
                               Style="{StaticResource BodyText}" Margin="0,8,0,0"/>

                    <!-- ① Python -->
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Python_Head}" Style="{StaticResource SubSecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Python_Body}" Style="{StaticResource BodyText}"/>
                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                            BorderBrush="{DynamicResource YellowBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource Help_UG_Setup_Python_Warn}"
                                   Foreground="{DynamicResource YellowBrush}" FontSize="12"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </Border>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Check}"
                               FontSize="12" Foreground="{DynamicResource Overlay0Brush}" Margin="0,10,0,2"/>
                    <Border Background="{DynamicResource DeepBgBrush}" CornerRadius="4" Padding="14,9" Margin="0,0,0,0">
                        <TextBlock Text="python --version"
                                   FontFamily="Consolas, Courier New" FontSize="12"
                                   Foreground="{DynamicResource GreenBrush}"/>
                    </Border>

                    <!-- ② ONNX Runtime -->
                    <TextBlock Text="{DynamicResource Help_UG_Setup_ONNX_Head}" Style="{StaticResource SubSecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_ONNX_Body}" Style="{StaticResource BodyText}"/>
                    <Border Background="{DynamicResource DeepBgBrush}" CornerRadius="4" Padding="14,9" Margin="0,8,0,0">
                        <TextBlock Text="pip install onnxruntime numpy scipy"
                                   FontFamily="Consolas, Courier New" FontSize="12"
                                   Foreground="{DynamicResource GreenBrush}"/>
                    </Border>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_AltCmd}"
                               FontSize="12" Foreground="{DynamicResource Overlay0Brush}" Margin="0,8,0,2"/>
                    <Border Background="{DynamicResource DeepBgBrush}" CornerRadius="4" Padding="14,9" Margin="0,0,0,0">
                        <TextBlock Text="python -m pip install onnxruntime numpy scipy"
                                   FontFamily="Consolas, Courier New" FontSize="12"
                                   Foreground="{DynamicResource GreenBrush}"/>
                    </Border>
                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                            BorderBrush="{DynamicResource YellowBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource Help_UG_Setup_Venv_Warn}"
                                   Foreground="{DynamicResource YellowBrush}" FontSize="12"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </Border>

                    <!-- ③ audio-separator -->
                    <TextBlock Text="{DynamicResource Help_UG_Setup_AudioSep_Head}" Style="{StaticResource SubSecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_AudioSep_Body}" Style="{StaticResource BodyText}"/>
                    <Border Background="{DynamicResource DeepBgBrush}" CornerRadius="4" Padding="14,9" Margin="0,8,0,0">
                        <TextBlock Text="pip install &quot;audio-separator[cpu]&quot;"
                                   FontFamily="Consolas, Courier New" FontSize="12"
                                   Foreground="{DynamicResource GreenBrush}"/>
                    </Border>
                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                            BorderBrush="{DynamicResource YellowBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource Help_UG_Setup_Venv_Warn}"
                                   Foreground="{DynamicResource YellowBrush}" FontSize="12"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </Border>

                    <!-- ④ noisereduce -->
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Noise_Head}" Style="{StaticResource SubSecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Noise_Body}" Style="{StaticResource BodyText}"/>
                    <Border Background="{DynamicResource DeepBgBrush}" CornerRadius="4" Padding="14,9" Margin="0,8,0,0">
                        <TextBlock Text="pip install noisereduce"
                                   FontFamily="Consolas, Courier New" FontSize="12"
                                   Foreground="{DynamicResource GreenBrush}"/>
                    </Border>
                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                            BorderBrush="{DynamicResource YellowBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource Help_UG_Setup_Venv_Warn}"
                                   Foreground="{DynamicResource YellowBrush}" FontSize="12"
                                   TextWrapping="Wrap" LineHeight="19"/>
                    </Border>

                    <!-- ⑤ FFmpeg -->
                    <TextBlock Text="{DynamicResource Help_UG_Setup_FFmpeg_Head}" Style="{StaticResource SubSecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_FFmpeg_Body}" Style="{StaticResource BodyText}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_FFmpeg_WingetNote}"
                               FontSize="12" Foreground="{DynamicResource Overlay0Brush}" Margin="0,8,0,2"
                               TextWrapping="Wrap"/>
                    <Border Background="{DynamicResource DeepBgBrush}" CornerRadius="4" Padding="14,9" Margin="0,0,0,0">
                        <TextBlock Text="winget install Gyan.FFmpeg"
                                   FontFamily="Consolas, Courier New" FontSize="12"
                                   Foreground="{DynamicResource GreenBrush}"/>
                    </Border>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_FFmpeg_ManualNote}"
                               FontSize="12" Foreground="{DynamicResource Overlay0Brush}"
                               TextWrapping="Wrap" LineHeight="19" Margin="0,10,0,0"/>

                    <!-- ⑥ 모델 다운로드 -->
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Model_Head}" Style="{StaticResource SubSecHead}"/>
                    <TextBlock Text="{DynamicResource Help_UG_Setup_Model_Body}" Style="{StaticResource BodyText}"/>

                </StackPanel>
            </ScrollViewer>

            <!-- ─────────────────────────────────
                 패널 2: 윤리적 사용
                 ───────────────────────────────── -->
            <ScrollViewer x:Name="PanelEthics"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource BgBrush}">
                <StackPanel Margin="32,28,32,36">

                    <TextBlock Text="{DynamicResource Help_Eth_Title}"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                    <Border Style="{StaticResource Divider}" Margin="0,12,0,14"/>

                    <!-- 배너: 저작권 책임 안내 -->
                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                            BorderBrush="{DynamicResource YellowBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="14,10" Margin="0,0,0,4">
                        <TextBlock Text="{DynamicResource Help_Eth_Banner}"
                                   Foreground="{DynamicResource YellowBrush}"
                                   FontSize="12.5" TextWrapping="Wrap" LineHeight="20"/>
                    </Border>

                    <!-- 프로젝트 목적 -->
                    <TextBlock Text="{DynamicResource Help_Eth_Purpose_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_Eth_Purpose_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 권리 존중 -->
                    <TextBlock Text="{DynamicResource Help_Eth_Rights_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_Eth_Rights_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 책임 있는 사용 (긍정) -->
                    <TextBlock Text="{DynamicResource Help_Eth_Good_Head}" Style="{StaticResource SecHead}"/>
                    <Border Background="{DynamicResource SuccessSurfaceBrush}"
                            BorderBrush="{DynamicResource GreenBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="14,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="✓" Foreground="{DynamicResource GreenBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Help_Eth_Good_1}" Foreground="{DynamicResource GreenBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="✓" Foreground="{DynamicResource GreenBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Help_Eth_Good_2}" Foreground="{DynamicResource GreenBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="{DynamicResource GreenBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Help_Eth_Good_3}" Foreground="{DynamicResource GreenBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 금지되는 사용 (부정) -->
                    <TextBlock Text="{DynamicResource Help_Eth_Bad_Head}" Style="{StaticResource SecHead}"/>
                    <Border Background="{DynamicResource WarningSurfaceBrush}"
                            BorderBrush="{DynamicResource RedBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="14,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="✗" Foreground="{DynamicResource RedBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Help_Eth_Bad_1}" Foreground="{DynamicResource RedBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="✗" Foreground="{DynamicResource RedBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Help_Eth_Bad_2}" Foreground="{DynamicResource RedBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="✗" Foreground="{DynamicResource RedBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Help_Eth_Bad_3}" Foreground="{DynamicResource RedBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✗" Foreground="{DynamicResource RedBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Help_Eth_Bad_4}" Foreground="{DynamicResource RedBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- AI 주의 -->
                    <TextBlock Text="{DynamicResource Help_Eth_AI_Head}" Style="{StaticResource SecHead}"/>
                    <TextBlock Text="{DynamicResource Help_Eth_AI_Body}" Style="{StaticResource BodyText}"/>

                    <!-- 푸터 노트 -->
                    <Border BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="0,1,0,0"
                            Margin="0,24,0,0" Padding="0,14,0,0">
                        <TextBlock Text="{DynamicResource Help_Eth_Note}"
                                   FontSize="11.5" Foreground="{DynamicResource Overlay0Brush}"
                                   TextWrapping="Wrap" LineHeight="19" FontStyle="Italic"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ─────────────────────────────────
                 패널 3: 셀라 정보
                 ───────────────────────────────── -->
            <ScrollViewer x:Name="PanelAbout"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource BgBrush}">
                <StackPanel Margin="32,28,32,36">

                    <!-- 앱 이름 & 부제 -->
                    <TextBlock Text="Selah"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource Help_Ab_Subtitle}"
                               FontSize="15" Foreground="{DynamicResource SubtextBrush}"
                               Margin="0,0,0,20"/>

                    <Border Style="{StaticResource Divider}" Margin="0,0,0,0"/>

                    <!-- 버전 / 라이선스 -->
                    <StackPanel Margin="0,16,0,4">
                        <TextBlock Text="{DynamicResource Help_Ab_Version}"
                                   FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{DynamicResource Help_Ab_License}"
                                   FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{DynamicResource Help_Ab_SourceLabel}"
                                       FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Help_Ab_SourceUrl}"
                                       FontSize="13" Foreground="{DynamicResource AccentBrush}"
                                       TextDecorations="Underline" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 설명 -->
                    <TextBlock Text="{DynamicResource Help_Ab_Desc}"
                               FontSize="13" Foreground="{DynamicResource SubtextBrush}"
                               TextWrapping="Wrap" LineHeight="22" Margin="0,16,0,0"/>

                    <!-- 오픈소스 라이브러리 -->
                    <TextBlock Text="{DynamicResource Help_Ab_Credits_Head}" Style="{StaticResource SecHead}"/>
                    <Border Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="5" Padding="16,12" Margin="0,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="•" Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="NAudio 2.2.1" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="MIT License — Microsoft" FontSize="11.5"
                                               Foreground="{DynamicResource Overlay0Brush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="•" Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Demucs" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="MIT License — Meta AI" FontSize="11.5"
                                               Foreground="{DynamicResource Overlay0Brush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="•" Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="FFmpeg" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="LGPL / GPL (선택 설치 / optional)" FontSize="11.5"
                                               Foreground="{DynamicResource Overlay0Brush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 마무리 -->
                    <Border BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="0,1,0,0"
                            Margin="0,28,0,0" Padding="0,18,0,0">
                        <TextBlock Text="{DynamicResource Help_Ab_Glory}"
                                   FontSize="15" FontStyle="Italic"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
