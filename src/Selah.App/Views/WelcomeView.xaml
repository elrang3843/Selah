<UserControl x:Class="Selah.App.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520">

            <!-- 로고 영역 -->
            <TextBlock Text="{DynamicResource Welcome_Title}"
                       FontSize="42" FontWeight="Light"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource Welcome_Subtitle}"
                       FontSize="16"
                       Foreground="{DynamicResource SubtextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- 빠른 시작 버튼 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                <Button Content="{DynamicResource Welcome_NewProject}"
                        Command="{Binding NewProjectCommand}"
                        Style="{StaticResource AccentButton}"
                        Width="160" Height="44" FontSize="14"
                        Margin="0,0,12,0"/>
                <Button Content="{DynamicResource Welcome_OpenProject}"
                        Command="{Binding OpenProjectCommand}"
                        Style="{StaticResource DefaultButton}"
                        Width="160" Height="44" FontSize="14"/>
            </StackPanel>

            <!-- 설명 카드 -->
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="24,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Welcome_Feature1_Title}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtextBrush}" FontSize="12"
                               Text="{DynamicResource Welcome_Feature1_Desc}"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="24,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Welcome_Feature2_Title}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtextBrush}" FontSize="12"
                               Text="{DynamicResource Welcome_Feature2_Desc}"/>
                </StackPanel>
            </Border>

            <!-- 단축키 힌트 -->
            <TextBlock Text="{DynamicResource Welcome_Shortcuts}"
                       FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,24,0,0"/>

            <!-- 라이선스 안내 -->
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,12,0,0"
                       Text="{DynamicResource Welcome_License}"/>
        </StackPanel>
    </Grid>
</UserControl>
