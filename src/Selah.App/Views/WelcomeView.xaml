<UserControl x:Class="Selah.App.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E2E">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520">

            <!-- 로고 영역 -->
            <TextBlock Text="셀라 (Selah)"
                       FontSize="42" FontWeight="Light"
                       Foreground="#89B4FA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="찬양사역용 MR편집기"
                       FontSize="16"
                       Foreground="#A6ADC8"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- 빠른 시작 버튼 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                <Button Content="＋ 새 프로젝트"
                        Command="{Binding NewProjectCommand}"
                        Style="{StaticResource AccentButton}"
                        Width="160" Height="44" FontSize="14"
                        Margin="0,0,12,0"/>
                <Button Content="📂 프로젝트 열기"
                        Command="{Binding OpenProjectCommand}"
                        Style="{StaticResource DefaultButton}"
                        Width="160" Height="44" FontSize="14"/>
            </StackPanel>

            <!-- 설명 카드 -->
            <Border Background="#181825" CornerRadius="8" Padding="24,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🎵  MR(반주) 추출"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#CDD6F4" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#7F849C" FontSize="12"
                               Text="음악·영상 파일에서 AI를 사용해 보컬을 제거하고 MR(악기 연주)만 추출합니다. 먼저 '모델 관리자'에서 분리 모델을 설치하세요."/>
                </StackPanel>
            </Border>

            <Border Background="#181825" CornerRadius="8" Padding="24,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🎛️  멀티트랙 편집 / 믹싱"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#CDD6F4" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#7F849C" FontSize="12"
                               Text="모델 없이도 WAV 파일을 트랙에 불러와 자르기·붙이기·볼륨·패닝·페이드를 편집하고 WAV/FLAC으로 내보낼 수 있습니다."/>
                </StackPanel>
            </Border>

            <!-- 단축키 힌트 -->
            <TextBlock Text="Space: 재생/정지  |  S: 클립 분할  |  Ctrl+S: 저장  |  Ctrl+E: 내보내기  |  F1: 도움말"
                       FontSize="11" Foreground="#45475A"
                       HorizontalAlignment="Center"
                       Margin="0,24,0,0"/>

            <!-- 라이선스 안내 -->
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#45475A"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,12,0,0"
                       Text="셀라(Selah)는 GPLv3 오픈소스입니다. 처리 대상 음원의 저작권은 사용자가 직접 확인하세요."/>
        </StackPanel>
    </Grid>
</UserControl>
