<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Catppuccin Mocha (Dark) -->
    <Color x:Key="BgColor">#1E1E2E</Color>
    <Color x:Key="SurfaceColor">#181825</Color>
    <Color x:Key="Surface1Color">#313244</Color>
    <Color x:Key="Surface2Color">#45475A</Color>
    <Color x:Key="TextColor">#CDD6F4</Color>
    <Color x:Key="SubtextColor">#A6ADC8</Color>
    <Color x:Key="Overlay0Color">#6C7086</Color>
    <Color x:Key="DeepBgColor">#0D0D1A</Color>
    <Color x:Key="MetronomeSurfaceColor">#151520</Color>
    <Color x:Key="AccentColor">#89B4FA</Color>
    <Color x:Key="GreenColor">#A6E3A1</Color>
    <Color x:Key="RedColor">#F38BA8</Color>
    <Color x:Key="YellowColor">#F9E2AF</Color>
    <Color x:Key="PeachColor">#FAB387</Color>
    <Color x:Key="WarningSurfaceColor">#2A2A1A</Color>
    <Color x:Key="SuccessSurfaceColor">#1A2A1A</Color>

    <SolidColorBrush x:Key="BgBrush"               Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"          Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface1Brush"         Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="Surface2Brush"         Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="TextBrush"             Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubtextBrush"          Color="{StaticResource SubtextColor}"/>
    <SolidColorBrush x:Key="Overlay0Brush"         Color="{StaticResource Overlay0Color}"/>
    <SolidColorBrush x:Key="DeepBgBrush"           Color="{StaticResource DeepBgColor}"/>
    <SolidColorBrush x:Key="MetronomeSurfaceBrush" Color="{StaticResource MetronomeSurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush"           Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="GreenBrush"            Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="RedBrush"              Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush"           Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="PeachBrush"            Color="{StaticResource PeachColor}"/>
    <SolidColorBrush x:Key="WarningSurfaceBrush"   Color="{StaticResource WarningSurfaceColor}"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush"   Color="{StaticResource SuccessSurfaceColor}"/>

    <!-- WPF Aero2 내부 메뉴/서브메뉴 팝업 리소스 키 재정의.
         Application 리소스는 WPF 테마 리소스보다 먼저 조회되므로 팝업에도 적용됩니다. -->
    <SolidColorBrush x:Key="Menu.Static.Background"                  Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Menu.Static.Border"                      Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="Menu.Static.Foreground"                  Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="Menu.Static.Separator"                   Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="Menu.Disabled.Foreground"                Color="{StaticResource Overlay0Color}"/>
    <SolidColorBrush x:Key="MenuItem.SubMenu.Background"             Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="MenuItem.SubMenu.Border"                 Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="MenuItem.Selected.Background"            Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="MenuItem.Selected.Border"                Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Background"           Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Border"               Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Disabled.Background"  Color="Transparent"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Disabled.Border"      Color="{StaticResource Surface1Color}"/>

</ResourceDictionary>
