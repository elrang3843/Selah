    <sys:String x:Key="Welcome_Feature1_Title">🎵  MR (Backing Track) Extraction</sys:String>
    <sys:String x:Key="Welcome_Feature1_Desc">Remove vocals from audio/video files using AI and extract the backing track (instrumental). Install a separation model from the Model Manager first.</sys:String>
