<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ 색상 팔레트 (Catppuccin Mocha) ═══ -->
    <Color x:Key="BgColor">#1E1E2E</Color>
    <Color x:Key="SurfaceColor">#181825</Color>
    <Color x:Key="Surface1Color">#313244</Color>
    <Color x:Key="Surface2Color">#45475A</Color>
    <Color x:Key="TextColor">#CDD6F4</Color>
    <Color x:Key="SubtextColor">#A6ADC8</Color>
    <Color x:Key="AccentColor">#89B4FA</Color>
    <Color x:Key="GreenColor">#A6E3A1</Color>
    <Color x:Key="RedColor">#F38BA8</Color>
    <Color x:Key="YellowColor">#F9E2AF</Color>
    <Color x:Key="PeachColor">#FAB387</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>

    <!-- ═══ 컨버터 ═══ -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ═══ 기본 텍스트 스타일 ═══ -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ═══ 버튼 기본 ═══ -->
    <Style TargetType="Button" x:Key="DefaultButton">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 강조 버튼 (재생/녹음 등) -->
    <Style TargetType="Button" x:Key="AccentButton" BasedOn="{StaticResource DefaultButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- 위험 버튼 (삭제 등) -->
    <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource DefaultButton}">
        <Setter Property="Background" Value="{StaticResource RedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource SurfaceBrush}"/>
    </Style>

    <!-- 아이콘 버튼 (텍스트 없이 아이콘만) -->
    <Style TargetType="Button" x:Key="IconButton" BasedOn="{StaticResource DefaultButton}">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ToggleButton -->
    <Style TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SurfaceBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slider -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ListBox -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
    </Style>

    <!-- Separator -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="Height" Value="1"/>
    </Style>

    <!-- Label -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- GroupBox -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
    </Style>

    <!-- ProgressBar -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="6"/>
    </Style>

    <!-- ScrollBar 다크 테마 -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    </Style>

    <!-- Window 기본 배경 -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
    </Style>

</ResourceDictionary>
