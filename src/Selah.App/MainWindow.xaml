<Window x:Class="Selah.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Selah.App.ViewModels"
        xmlns:views="clr-namespace:Selah.App.Views"
        xmlns:conv="clr-namespace:Selah.App.Converters"
        Title="{Binding WindowTitle}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        Background="#1E1E2E">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <!-- 키보드 단축키 -->
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N"           Command="{Binding NewProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+O"           Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+S"           Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S"     Command="{Binding SaveAsCommand}"/>
        <KeyBinding Gesture="Ctrl+E"           Command="{Binding ExportCommand}"/>
        <KeyBinding Gesture="Space"            Command="{Binding PlayCommand}"/>
        <KeyBinding Gesture="Home"             Command="{Binding ReturnToStartCommand}"/>
        <KeyBinding Gesture="S"               Command="{Binding SplitAtPlayheadCommand}"/>
        <KeyBinding Gesture="M"               Command="{Binding ToggleMetronomeCommand}"/>
        <KeyBinding Gesture="N"               Command="{Binding ToggleSnapCommand}"/>
        <KeyBinding Gesture="Delete"          Command="{Binding DeleteSelectedTrackCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ═══ 메뉴바 ═══ -->
        <Menu DockPanel.Dock="Top" Background="#181825" Foreground="#CDD6F4"
              FontFamily="Segoe UI, Malgun Gothic" FontSize="13">
            <MenuItem Header="파일(_F)">
                <MenuItem Header="새 프로젝트(_N)..." Command="{Binding NewProjectCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="열기(_O)..." Command="{Binding OpenProjectCommand}"
                          InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="저장(_S)" Command="{Binding SaveProjectCommand}"
                          InputGestureText="Ctrl+S"/>
                <MenuItem Header="다른 이름으로 저장..." Command="{Binding SaveAsCommand}"
                          InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="오디오/영상 불러오기..." Command="{Binding ImportAudioCommand}"/>
                <Separator/>
                <MenuItem Header="WAV로 내보내기..." Command="{Binding ExportCommand}"
                          InputGestureText="Ctrl+E"/>
                <Separator/>
                <MenuItem Header="종료(_X)" Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="편집(_E)">
                <MenuItem Header="실행 취소" InputGestureText="Ctrl+Z" IsEnabled="False"/>
                <MenuItem Header="다시 실행" InputGestureText="Ctrl+Y" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="클립 분할" Command="{Binding SplitAtPlayheadCommand}"
                          InputGestureText="S"/>
                <MenuItem Header="선택 삭제" Command="{Binding DeleteSelectedTrackCommand}"
                          InputGestureText="Del"/>
            </MenuItem>

            <MenuItem Header="트랙(_T)">
                <MenuItem Header="새 트랙 추가" Command="{Binding AddTrackCommand}"/>
                <MenuItem Header="선택 트랙 삭제" Command="{Binding DeleteSelectedTrackCommand}"/>
            </MenuItem>

            <MenuItem Header="도구(_O)">
                <MenuItem Header="모델 관리자..." Click="MenuModelManager_Click"/>
                <MenuItem Header="하드웨어 진단..." Click="MenuHardwareDiag_Click"/>
                <Separator/>
                <MenuItem Header="FFmpeg 설치 안내..." Click="MenuFFmpegGuide_Click"/>
            </MenuItem>

            <MenuItem Header="도움말(_H)">
                <MenuItem Header="단축키 목록" Click="MenuShortcuts_Click" InputGestureText="F1"/>
                <Separator/>
                <MenuItem Header="윤리적 사용 가이드라인..." Click="MenuEthics_Click"/>
                <MenuItem Header="셀라(Selah) 정보..." Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══ 상태바 ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Background="#181825" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#A6ADC8" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem>
                <ProgressBar Width="100" Height="6"
                             IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SampleRateText}"
                               Foreground="#6C7086" FontSize="11" Margin="0,0,12,0"
                               Visibility="{Binding HasProject, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding HardwareStatusText}"
                               Foreground="#6C7086" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ 메인 콘텐츠 ═══ -->
        <Grid>
            <!-- 프로젝트 없을 때 환영 화면 -->
            <views:WelcomeView
                DataContext="{Binding}"
                Visibility="{Binding HasProject, Converter={StaticResource InvBoolToVis}}"/>

            <!-- 프로젝트 편집 화면 -->
            <DockPanel Visibility="{Binding HasProject, Converter={StaticResource BoolToVis}}">

                <!-- 트랜스포트 바 -->
                <views:TransportBar DockPanel.Dock="Top" DataContext="{Binding}"/>

                <!-- 구분선 -->
                <Separator DockPanel.Dock="Top" Height="1" Margin="0"/>

                <!-- 타임라인 뷰 (나머지 공간 전부) -->
                <views:TimelineView DataContext="{Binding}"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
