<Window x:Class="Selah.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Selah.App.ViewModels"
        xmlns:views="clr-namespace:Selah.App.Views"
        Title="{Binding WindowTitle}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        Background="{DynamicResource BgBrush}">

    <!-- 키보드 단축키 -->
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N"           Command="{Binding NewProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+O"           Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+S"           Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S"     Command="{Binding SaveAsCommand}"/>
        <KeyBinding Gesture="Ctrl+E"           Command="{Binding ExportCommand}"/>
        <KeyBinding Gesture="Space"            Command="{Binding PlayCommand}"/>
        <KeyBinding Gesture="Home"             Command="{Binding ReturnToStartCommand}"/>
        <KeyBinding Key="S"                    Command="{Binding SplitAtPlayheadCommand}"/>
        <KeyBinding Key="M"                    Command="{Binding ToggleMetronomeCommand}"/>
        <KeyBinding Key="N"                    Command="{Binding ToggleSnapCommand}"/>
        <KeyBinding Gesture="Delete"           Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ═══ 메뉴바 ═══ -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
              FontFamily="Segoe UI, Malgun Gothic" FontSize="13">
            <MenuItem Header="{DynamicResource Menu_File}">
                <MenuItem Header="{DynamicResource Menu_File_New}" Command="{Binding NewProjectCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="{DynamicResource Menu_File_Open}" Command="{Binding OpenProjectCommand}"
                          InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Save}" Command="{Binding SaveProjectCommand}"
                          InputGestureText="Ctrl+S"/>
                <MenuItem Header="{DynamicResource Menu_File_SaveAs}" Command="{Binding SaveAsCommand}"
                          InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Import}" Command="{Binding ImportAudioCommand}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Export}" Command="{Binding ExportCommand}"
                          InputGestureText="Ctrl+E"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Exit}" Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Edit}">
                <MenuItem Header="{DynamicResource Menu_Edit_Undo}" InputGestureText="Ctrl+Z" IsEnabled="False"/>
                <MenuItem Header="{DynamicResource Menu_Edit_Redo}" InputGestureText="Ctrl+Y" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_Split}" Command="{Binding SplitAtPlayheadCommand}"
                          InputGestureText="S"/>
                <MenuItem Header="{DynamicResource Menu_Edit_Delete}" Command="{Binding DeleteCommand}"
                          InputGestureText="Del"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_Separate}" Command="{Binding SeparateClipCommand}"/>
                <MenuItem Header="{DynamicResource Menu_Edit_ReduceNoise}" Command="{Binding ReduceNoiseCommand}"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Track}">
                <MenuItem Header="{DynamicResource Menu_Track_Add}" Command="{Binding AddTrackCommand}"/>
                <MenuItem Header="{DynamicResource Menu_Track_Delete}" Command="{Binding DeleteSelectedTrackCommand}"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Tools}">
                <MenuItem Header="{DynamicResource Menu_Tools_ModelManager}" Click="MenuModelManager_Click"/>
                <MenuItem Header="{DynamicResource Menu_Tools_HardwareDiag}" Click="MenuHardwareDiag_Click"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Tools_FFmpegGuide}" Click="MenuFFmpegGuide_Click"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Language}">
                <MenuItem Header="한국어" Click="MenuLang_Ko_Click"/>
                <MenuItem Header="English" Click="MenuLang_En_Click"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Theme_Dark}"  Click="MenuTheme_Click" Tag="dark"/>
                <MenuItem Header="{DynamicResource Menu_Theme_Light}" Click="MenuTheme_Click" Tag="light"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Help}">
                <MenuItem Header="{DynamicResource Menu_Help_Shortcuts}" Click="MenuShortcuts_Click" InputGestureText="F1"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Help_Ethics}" Click="MenuEthics_Click"/>
                <MenuItem Header="{DynamicResource Menu_Help_About}" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══ 상태바 ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SubtextBrush}" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem>
                <ProgressBar Width="100" Height="6"
                             IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SampleRateText}"
                               Foreground="{DynamicResource Overlay0Brush}" FontSize="11" Margin="0,0,12,0"
                               Visibility="{Binding HasProject, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding HardwareStatusText}"
                               Foreground="{DynamicResource Overlay0Brush}" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ 메인 콘텐츠 ═══ -->
        <Grid>
            <!-- 프로젝트 없을 때 환영 화면 -->
            <views:WelcomeView
                DataContext="{Binding}"
                Visibility="{Binding HasProject, Converter={StaticResource InvBoolToVis}}"/>

            <!-- 프로젝트 편집 화면 -->
            <DockPanel Visibility="{Binding HasProject, Converter={StaticResource BoolToVis}}">

                <!-- 트랜스포트 바 -->
                <views:TransportBar DockPanel.Dock="Top" DataContext="{Binding}"/>

                <!-- 구분선 -->
                <Separator DockPanel.Dock="Top" Height="1" Margin="0"/>

                <!-- 타임라인 뷰 (나머지 공간 전부) -->
                <views:TimelineView DataContext="{Binding}"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
