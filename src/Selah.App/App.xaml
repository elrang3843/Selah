<Application x:Class="Selah.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Selah.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Lang/Ko.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── 공통 컨버터 (앱 전역 등록) ── -->
            <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
            <conv:InverseBoolConverter             x:Key="InverseBoolConverter"/>
            <conv:NullToVisibilityConverter        x:Key="NullToVisibilityConverter"/>
            <conv:InstalledColorConverter          x:Key="InstalledColorConverter"/>
            <conv:InstalledTextBrushConverter      x:Key="InstalledTextBrushConverter"/>
            <conv:InstalledStatusConverter         x:Key="InstalledStatusConverter"/>
            <conv:PlayPauseConverter               x:Key="PlayPauseConverter"/>
            <conv:HexToColorConverter              x:Key="HexToColorConverter"/>
            <conv:MuteColorConverter               x:Key="MuteColorConverter"/>
            <conv:SoloColorConverter               x:Key="SoloColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
