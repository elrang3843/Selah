<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>Selah</AssemblyName>
    <RootNamespace>Selah.App</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- 앱이 Windows 전용(net8.0-windows)이므로 플랫폼 호환성 경고를 억제합니다 -->
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Selah.Core\Selah.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>
  <ItemGroup>
    <!-- demucs_runner.py를 빌드 출력의 scripts/ 폴더에 복사 -->
    <Content Include="..\..\scripts\demucs_runner.py">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>scripts\demucs_runner.py</TargetPath>
    </Content>
  </ItemGroup>
</Project>
